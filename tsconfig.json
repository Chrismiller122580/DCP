{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@dcp/core": ["packages/core/src"],
      "@dcp/blockchain": ["packages/blockchain/src"],
      "@dcp/xrpl-service": ["packages/xrpl-service/src"],
      "@dcp/solana-service": ["packages/solana-service/src"],
      "@dcp/evm-service": ["packages/evm-service/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
